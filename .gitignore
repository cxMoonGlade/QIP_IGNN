# Academic release: only training entrypoint, model factory, and qignn/.

# Whitelist: single-segment names at repo root (non-dot)
/*
!/.gitignore
!/README.md
!/requirements.txt
!/train.py
!/model_factory.py
!/qignn
!/additional_figures_and_data/
!/additional_figures_and_data/**

# Root dotfiles: experiment queues, locks, workers, ad-hoc dirs. The pattern
# `/*` above does *not* match names starting with `.`, so these must be listed
# (see gitignore(5); local orchestration should never be published).
/.*
!/.gitignore
/.task_locks/

# Bytecode and packaging
**/__pycache__/
*.py[cod]
*.pyo
.eggs/
*.egg-info/

# Local data and run outputs
/data/
/results/
